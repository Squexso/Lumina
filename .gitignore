# ── Build output ───────────────────────────────────────────────
build/
out/
bin/
*.class

# ── Gradle ─────────────────────────────────────────────────────
.gradle/
**/.gradle/

# ── IDE ────────────────────────────────────────────────────────
.idea/
*.iml
.vscode/
.settings/
.classpath
.project

# ── Minecraft dev-run dirs (created by the loaders) ────────────
run/
**/run/

# ── OS junk ────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Logs & local secrets ───────────────────────────────────────
*.log
*.pfx
cert.*
.env
**/.env

# ── Discord bot: secrets, local state & Python artifacts ───────
# The bot token lives in launcher/.env (never commit it). The db and config
# files are local runtime state; __pycache__/*.pyc are build artifacts.
*.db
__pycache__/
**/__pycache__/
*.pyc
